# ─── Client Environment Variables ──────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# URL of the ChatFlow backend API (no trailing slash)
# Local:      http://localhost:5000/api
# Production: https://your-server.railway.app/api   (or Render, Fly.io, etc.)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# WebSocket base URL — same host as the API but WITHOUT the /api path
# Local:      http://localhost:5000
# Production: https://your-server.railway.app
NEXT_PUBLIC_WS_URL=http://localhost:5000
